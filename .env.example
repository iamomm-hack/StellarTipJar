# Stellar Tip Jar - Level 2 config
# Copy this file to .env and fill with your deployed contract details.

VITE_TIP_CONTRACT_ID=
VITE_TIP_CONTRACT_READ_METHOD=get_total_tips
VITE_TIP_CONTRACT_WRITE_METHOD=record_tip

# Optional fallback reader for contract simulation when wallet is not connected.
VITE_TIP_READER_PUBLIC_KEY=
